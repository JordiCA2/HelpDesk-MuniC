<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="http://xmlns.jcp.org/xml/ns/persistence" version="2.2">  <!-- Define Persistence Unit -->
  <persistence-unit name="helpdeskPU">
    <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
    <properties>
      <property name="javax.persistence.jdbc.driver" value="org.postgresql.Driver"/>
      <property name="javax.persistence.jdbc.url" value="jdbc:postgresql://localhost:5432/helpdesk_cocachacra"/>
      <property name="javax.persistence.jdbc.user" value="helpdesk_user"/>
      <property name="javax.persistence.jdbc.password" value="cambiar_esta_contraseña"/>
      <property name="hibernate.dialect" value="org.hibernate.dialect.PostgreSQL10Dialect"/>
      <property name="hibernate.hbm2ddl.auto" value="validate"/>
      <property name="hibernate.show_sql" value="false"/>
      <property name="hibernate.format_sql" value="true"/>
    </properties>
  </persistence-unit>
</persistence>
